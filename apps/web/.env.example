# Server-side fetch (catalog SSR); falls back to NEXT_PUBLIC_API_URL
API_URL=http://localhost:3001
NEXT_PUBLIC_API_URL=http://localhost:3001

# Clerk (ключи — из Dashboard → API Keys; тот же инстанс, что и apps/api CLERK_SECRET_KEY)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Пути страниц Clerk (обязательно согласовать с app/sign-in и app/sign-up)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
